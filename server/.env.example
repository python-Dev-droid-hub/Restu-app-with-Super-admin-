# Server Configuration
PORT=3101
NODE_ENV=production
# The public URL of your server (e.g. https://api.yourdomain.com)
SERVER_URL=http://localhost:3101

# Database Configuration
# Use a production MongoDB connection string (e.g. MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27019/restaurant_app

# JWT Configuration
# Change these to strong random strings in production
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_REFRESH_EXPIRE=30d

# CORS Configuration
# Set this to your frontend production URL (comma separated if multiple)
CORS_ORIGIN=http://localhost:5173,https://your-restaurant-app.com

# Cookie Configuration
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Stripe Configuration (if applicable)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
