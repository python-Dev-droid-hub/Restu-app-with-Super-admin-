# Server Configuration
# Keep 3101 in dev — mobile app expects this port (see mobile EXPO_PUBLIC_API_DEV_PORT)
PORT=3101
NODE_ENV=development
# The public URL of your server (e.g. https://api.yourdomain.com)
SERVER_URL=http://localhost:3101

# Database Configuration
# Use a production MongoDB connection string (e.g. MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27019/restaurant_app

# JWT Configuration
# Change these to strong random strings in production
# Use: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=30m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_REFRESH_EXPIRE=7d

# Stricter auth rate limit (per IP, 15 min window)
AUTH_RATE_LIMIT_MAX=10

# CORS Configuration
# Comma-separated browser origins allowed to call the API (required in production).
# If SERVER_URL is set, any origin on the same hostname is also allowed (e.g. web on :5175, API on :3101).
CORS_ORIGIN=http://localhost:5173,http://31.97.189.252:5175
# Public API URL (used for uploads, CORS same-host matching, etc.)
SERVER_URL=http://localhost:3101
# Optional explicit web app URL (also added to CORS allowlist)
# FRONTEND_URL=http://31.97.189.252:5175

# Cookie Configuration (HTTP VPS: COOKIE_SECURE=false, COOKIE_SAMESITE=lax)
# HTTPS production: COOKIE_SECURE=true, COOKIE_SAMESITE=none (or lax if same-origin proxy)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads

# Thermal printer (network ESC/POS, port 9100 default)
# Configure printers per branch via POST /api/printers

# Rider GPS (in-memory store; optional Redis URL for production)
# REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Firebase Cloud Messaging (optional — push notifications)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Stripe Configuration (if applicable)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
