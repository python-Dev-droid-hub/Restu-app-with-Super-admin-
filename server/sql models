-- ============================================================================ 
-- UPDATED RESTAURANT / FOOD DELIVERY PLATFORM SCHEMA
-- WITH: Product Sizes, Multi-Branch Support, Branch Manager Role, Coupon-Deal Rules
-- PostgreSQL + Redis Friendly
-- ============================================================================

-- EXTENSIONS
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
CREATE EXTENSION IF NOT EXISTS postgis;

-- ============================================================================ 
-- BRANCHES (NEW - Multi-Branch Support)
-- ============================================================================ 
CREATE TABLE branches (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    branch_code VARCHAR(20) UNIQUE NOT NULL, -- e.g., "BR001", "BR002"
    branch_name VARCHAR(255) NOT NULL,
    
    -- Address Information
    address_line VARCHAR(500) NOT NULL,
    city VARCHAR(100) NOT NULL,
    state VARCHAR(100),
    postal_code VARCHAR(20),
    country VARCHAR(100) DEFAULT 'Pakistan',
    
    -- Location
    lat DOUBLE PRECISION,
    lng DOUBLE PRECISION,
    location GEOGRAPHY(POINT, 4326),
    
    -- Service Area (radius in meters)
    delivery_radius INT DEFAULT 5000, -- 5km default
    
    -- Branch Manager
    branch_manager_id UUID,
    
    -- Contact Info
    phone_number VARCHAR(20),
    email VARCHAR(255),
    
    -- Operating Hours (JSONB for flexibility)
    operating_hours JSONB, -- {"monday": {"open": "09:00", "close": "22:00"}, ...}
    
    -- Status
    is_active BOOLEAN DEFAULT TRUE,
    accepts_delivery BOOLEAN DEFAULT TRUE,
    accepts_dine_in BOOLEAN DEFAULT TRUE,
    accepts_takeaway BOOLEAN DEFAULT TRUE,
    
    -- Timestamps
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    deleted_at TIMESTAMP,
    
    CONSTRAINT fk_branch_manager FOREIGN KEY (branch_manager_id)
        REFERENCES users(id) ON DELETE SET NULL
);

CREATE INDEX idx_branches_location ON branches USING GIST (location);
CREATE INDEX idx_branches_active ON branches(is_active) WHERE deleted_at IS NULL;
CREATE INDEX idx_branches_manager ON branches(branch_manager_id);

-- ============================================================================ 
-- USERS (UPDATED - Added BRANCH_MANAGER Role)
-- ============================================================================ 
CREATE TABLE users (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    email VARCHAR(255) UNIQUE NOT NULL,
    password_hash VARCHAR(255),
    display_name VARCHAR(255),
    phone_number VARCHAR(20),
    
    -- UPDATED: Added BRANCH_MANAGER role
    role VARCHAR(20) NOT NULL CHECK (role IN ('CUSTOMER','RIDER','ADMIN','WAITER','CHEF','BRANCH_MANAGER')),

    profile_image VARCHAR(500),
    email_verified BOOLEAN DEFAULT FALSE,
    phone_verified BOOLEAN DEFAULT FALSE,
    is_active BOOLEAN DEFAULT TRUE,

    -- For Riders
    vehicle_number VARCHAR(50),
    vehicle_type VARCHAR(50),
    
    -- For Chefs
    specialization VARCHAR(100),
    
    -- For Waiters
    assigned_section VARCHAR(50),
    
    -- NEW: Branch Assignment for staff members
    assigned_branch_id UUID,

    fcm_token TEXT,

    last_login_at TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    deleted_at TIMESTAMP,
    
    CONSTRAINT fk_user_branch FOREIGN KEY (assigned_branch_id)
        REFERENCES branches(id) ON DELETE SET NULL
);

CREATE INDEX idx_users_email ON users(email) WHERE deleted_at IS NULL;
CREATE INDEX idx_users_role ON users(role) WHERE deleted_at IS NULL;
CREATE INDEX idx_users_branch ON users(assigned_branch_id);

-- ============================================================================ 
-- Dining TABLES (UPDATED - Linked to Branch)
-- ============================================================================ 
CREATE TABLE restaurant_tables (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    branch_id UUID NOT NULL, -- NEW: Link to branch
    table_number VARCHAR(20) NOT NULL,
    seating_capacity INT NOT NULL CHECK (seating_capacity > 0),
    section VARCHAR(50),
    floor_number INT DEFAULT 1,
    qr_code_url VARCHAR(500),

    status VARCHAR(20) DEFAULT 'AVAILABLE' CHECK (
        status IN ('AVAILABLE','OCCUPIED','RESERVED','CLEANING','OUT_OF_SERVICE')
    ),

    current_waiter_id UUID,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    deleted_at TIMESTAMP,

    CONSTRAINT fk_table_branch FOREIGN KEY (branch_id)
        REFERENCES branches(id) ON DELETE CASCADE,
    CONSTRAINT fk_table_waiter FOREIGN KEY (current_waiter_id)
        REFERENCES users(id) ON DELETE SET NULL,
    -- Table number unique per branch
    CONSTRAINT unique_table_per_branch UNIQUE (branch_id, table_number)
);

CREATE INDEX idx_tables_branch ON restaurant_tables(branch_id);
CREATE INDEX idx_tables_status ON restaurant_tables(status);

-- ============================================================================ 
-- CUSTOMER ADDRESSES
-- ============================================================================ 
CREATE TABLE customer_addresses (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    customer_id UUID NOT NULL,
    label VARCHAR(50),
    address_line VARCHAR(500) NOT NULL,
    city VARCHAR(100),
    postal_code VARCHAR(20),

    lat DOUBLE PRECISION,
    lng DOUBLE PRECISION,
    location GEOGRAPHY(POINT, 4326),

    is_default BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    deleted_at TIMESTAMP,

    CONSTRAINT fk_address_customer FOREIGN KEY (customer_id)
        REFERENCES users(id) ON DELETE CASCADE
);

CREATE INDEX idx_addresses_customer ON customer_addresses(customer_id);
CREATE INDEX idx_addresses_location ON customer_addresses USING GIST (location);

-- ============================================================================ 
-- CATEGORIES
-- ============================================================================ 
CREATE TABLE categories (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    name VARCHAR(100) UNIQUE NOT NULL,
    description TEXT,
    image_url VARCHAR(500),
    display_order INT DEFAULT 0,
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    deleted_at TIMESTAMP
);

-- ============================================================================ 
-- PRODUCTS (Base Product Definition)
-- ============================================================================ 
CREATE TABLE products (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    category_id UUID,
    name VARCHAR(255) NOT NULL,
    description TEXT,
    
    -- Base price (for products without sizes like Burger, Fries, etc.)
    price NUMERIC(12,2) CHECK (price >= 0),
    
    -- NEW: Flag to indicate if this product has multiple sizes
    has_sizes BOOLEAN DEFAULT FALSE,
    
    image_url VARCHAR(500),

    is_available BOOLEAN DEFAULT TRUE,
    preparation_time INT,

    is_vegetarian BOOLEAN DEFAULT FALSE,
    spice_level VARCHAR(20),

    available_for_delivery BOOLEAN DEFAULT TRUE,
    available_for_dine_in BOOLEAN DEFAULT TRUE,
    available_for_takeaway BOOLEAN DEFAULT TRUE,

    order_count INT DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    deleted_at TIMESTAMP,

    CONSTRAINT fk_product_category FOREIGN KEY (category_id)
        REFERENCES categories(id) ON DELETE SET NULL
);

CREATE INDEX idx_products_category ON products(category_id);
CREATE INDEX idx_products_available ON products(is_available);

COMMENT ON COLUMN products.price IS 'Base price for products without sizes. If has_sizes=TRUE, price comes from product_sizes table';
COMMENT ON COLUMN products.has_sizes IS 'TRUE if product has multiple sizes (Pizza, Drinks). FALSE for simple products (Burger, Fries)';

-- ============================================================================ 
-- SIZES (MASTER TABLE - Admin manages all available sizes here)
-- ============================================================================ 
CREATE TABLE sizes (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    size_name VARCHAR(50) UNIQUE NOT NULL, -- e.g., "Small", "Medium", "Large", "Extra Large", "Family Size"
    display_order INT DEFAULT 0, -- Order to display sizes (Small=1, Medium=2, Large=3, etc.)
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    deleted_at TIMESTAMP
);

CREATE INDEX idx_sizes_active ON sizes(is_active) WHERE deleted_at IS NULL;

COMMENT ON TABLE sizes IS 'Master table of all available sizes. Admin can add/manage sizes like Small, Medium, Large, Extra Large, Family Size, etc.';

-- Insert default sizes
INSERT INTO sizes (size_name, display_order, is_active) VALUES
('Small', 1, TRUE),
('Medium', 2, TRUE),
('Large', 3, TRUE),
('Extra Large', 4, TRUE),
('Family Size', 5, TRUE);

-- ============================================================================ 
-- PRODUCT SIZES (Links products to sizes with prices)
-- ============================================================================ 
CREATE TABLE product_sizes (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    product_id UUID NOT NULL,
    size_id UUID NOT NULL, -- Reference to master sizes table
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    deleted_at TIMESTAMP,
    
    CONSTRAINT fk_product_size_product FOREIGN KEY (product_id)
        REFERENCES products(id) ON DELETE CASCADE,
    CONSTRAINT fk_product_size_size FOREIGN KEY (size_id)
        REFERENCES sizes(id) ON DELETE RESTRICT,
    CONSTRAINT unique_product_size UNIQUE (product_id, size_id)
);

CREATE INDEX idx_product_sizes_product ON product_sizes(product_id);
CREATE INDEX idx_product_sizes_size ON product_sizes(size_id);

COMMENT ON TABLE product_sizes IS 'Links products to sizes with specific prices. Only for products that need sizes (Pizza, Drinks, etc.)';

-- ============================================================================ 
-- PRODUCT CUSTOMIZATIONS (For Toppings, Add-ons, etc.)
-- ============================================================================ 
CREATE TABLE product_customizations (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    product_id UUID NOT NULL,
    option_name VARCHAR(100) NOT NULL, -- e.g., "Extra Toppings", "Spice Level"
    option_values JSONB, -- e.g., ["Cheese", "Olives", "Mushrooms"]
    extra_price NUMERIC(10,2) DEFAULT 0 CHECK (extra_price >= 0),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    deleted_at TIMESTAMP,

    CONSTRAINT fk_custom_product FOREIGN KEY (product_id)
        REFERENCES products(id) ON DELETE CASCADE,
    CONSTRAINT unique_product_option UNIQUE (product_id, option_name)
);

CREATE INDEX idx_customizations_product ON product_customizations(product_id);

-- ============================================================================ 
-- DEALS (UPDATED - Linked to Branch)
-- ============================================================================ 
CREATE TABLE deals (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    branch_id UUID, -- NEW: NULL means applicable to all branches
    
    title VARCHAR(255) NOT NULL,
    description TEXT,

    discount_type VARCHAR(20) CHECK (discount_type IN ('PERCENTAGE','FIXED_AMOUNT')),
    discount_value NUMERIC(10,2) NOT NULL,
    max_discount_amount NUMERIC(10,2),
    min_order_amount NUMERIC(10,2) DEFAULT 0,

    start_date TIMESTAMP NOT NULL,
    expiry_date TIMESTAMP NOT NULL,
    image_url VARCHAR(500),
    is_active BOOLEAN DEFAULT TRUE,
    
    -- NEW: Coupon exclusivity flag
    exclude_coupons BOOLEAN DEFAULT TRUE, -- If TRUE, coupons cannot be applied with this deal

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    deleted_at TIMESTAMP,
    
    CONSTRAINT fk_deal_branch FOREIGN KEY (branch_id)
        REFERENCES branches(id) ON DELETE CASCADE,
    CHECK (expiry_date > start_date)
);

CREATE INDEX idx_deals_branch ON deals(branch_id);
CREATE INDEX idx_deals_active ON deals(is_active);
CREATE INDEX idx_deals_dates ON deals(start_date, expiry_date);

-- ============================================================================ 
-- DEAL PRODUCTS (NEW - Which products have deals)
-- ============================================================================ 
CREATE TABLE deal_products (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    deal_id UUID NOT NULL,
    product_id UUID NOT NULL,
    
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    
    CONSTRAINT fk_deal_product_deal FOREIGN KEY (deal_id)
        REFERENCES deals(id) ON DELETE CASCADE,
    CONSTRAINT fk_deal_product_product FOREIGN KEY (product_id)
        REFERENCES products(id) ON DELETE CASCADE,
    CONSTRAINT unique_deal_product UNIQUE (deal_id, product_id)
);

CREATE INDEX idx_deal_products_deal ON deal_products(deal_id);
CREATE INDEX idx_deal_products_product ON deal_products(product_id);

-- ============================================================================ 
-- COUPONS (UPDATED - Linked to Branch)
-- ============================================================================ 
CREATE TABLE coupons (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    branch_id UUID, -- NEW: NULL means applicable to all branches
    
    code VARCHAR(50) UNIQUE NOT NULL, -- e.g., "WELCOME10"
    description TEXT,
    discount_type VARCHAR(20) NOT NULL CHECK (discount_type IN ('PERCENTAGE','FIXED_AMOUNT')),
    discount_value NUMERIC(10,2) NOT NULL CHECK (discount_value >= 0),
    
    max_usage INT DEFAULT 1 CHECK (max_usage > 0), -- total times coupon can be used
    used_count INT DEFAULT 0, -- usage counter
    
    -- NEW: Per-customer usage limit
    max_usage_per_customer INT DEFAULT 1 CHECK (max_usage_per_customer > 0),
    
    -- NEW: Minimum order amount to use coupon
    min_order_amount NUMERIC(12,2) DEFAULT 0,
    
    -- NEW: Maximum discount cap
    max_discount_amount NUMERIC(12,2),
    
    start_date TIMESTAMP NOT NULL,
    expiry_date TIMESTAMP NOT NULL,
    is_active BOOLEAN DEFAULT TRUE,
    
    -- NEW: Exclude products with active deals
    exclude_deal_products BOOLEAN DEFAULT TRUE, -- If TRUE, cannot apply to products with active deals
    
    created_by UUID, -- admin who created the coupon
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_coupon_admin FOREIGN KEY (created_by)
        REFERENCES users(id),
    CONSTRAINT fk_coupon_branch FOREIGN KEY (branch_id)
        REFERENCES branches(id) ON DELETE CASCADE,
    CHECK (expiry_date > start_date)
);

CREATE INDEX idx_coupons_branch ON coupons(branch_id);
CREATE INDEX idx_coupons_code ON coupons(code) WHERE is_active = TRUE;
CREATE INDEX idx_coupons_dates ON coupons(start_date, expiry_date);

-- ============================================================================ 
-- COUPON REDEMPTIONS
-- ============================================================================ 
CREATE TABLE coupon_redemptions (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    coupon_id UUID NOT NULL,
    order_id UUID NOT NULL,
    customer_id UUID NOT NULL,
    discount_amount NUMERIC(12,2) NOT NULL,
    redeemed_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_redemption_coupon FOREIGN KEY (coupon_id)
        REFERENCES coupons(id) ON DELETE CASCADE,
    CONSTRAINT fk_redemption_order FOREIGN KEY (order_id)
        REFERENCES orders(id) ON DELETE CASCADE,
    CONSTRAINT fk_redemption_customer FOREIGN KEY (customer_id)
        REFERENCES users(id) ON DELETE CASCADE,
    CONSTRAINT unique_customer_coupon_order UNIQUE (coupon_id, order_id, customer_id)
);

CREATE INDEX idx_redemptions_coupon ON coupon_redemptions(coupon_id);
CREATE INDEX idx_redemptions_customer ON coupon_redemptions(customer_id);
CREATE INDEX idx_redemptions_order ON coupon_redemptions(order_id);

-- ============================================================================ 
-- ORDERS (UPDATED - Linked to Branch)
-- ============================================================================ 
CREATE TABLE orders (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    order_number VARCHAR(50) UNIQUE NOT NULL,
    
    branch_id UUID NOT NULL, -- NEW: Link to branch

    order_type VARCHAR(20) NOT NULL CHECK (
        order_type IN ('DELIVERY','DINE_IN','TAKEAWAY')
    ),

    customer_id UUID NOT NULL,
    rider_id UUID,
    waiter_id UUID,
    chef_id UUID,
    table_id UUID,

    subtotal NUMERIC(12,2) NOT NULL,
    discount_amount NUMERIC(12,2) DEFAULT 0, -- total discount including deal and coupon
    coupon_discount NUMERIC(12,2) DEFAULT 0, -- discount from coupon only
    deal_discount NUMERIC(12,2) DEFAULT 0, -- NEW: discount from deal only
    tax_amount NUMERIC(12,2) DEFAULT 0,
    delivery_fee NUMERIC(12,2) DEFAULT 0,
    service_charge NUMERIC(12,2) DEFAULT 0,
    total_amount NUMERIC(12,2) NOT NULL,

    coupon_id UUID, -- applied coupon
    deal_id UUID,

    status VARCHAR(30) NOT NULL DEFAULT 'PENDING',
    payment_status VARCHAR(20) DEFAULT 'PENDING',
    payment_method VARCHAR(50),

    address_line VARCHAR(500),
    delivery_location GEOGRAPHY(POINT, 4326),

    special_instructions TEXT,
    rejection_reason TEXT,
    cancellation_reason TEXT,

    kitchen_accepted_at TIMESTAMP,
    ready_at TIMESTAMP,
    picked_up_at TIMESTAMP,
    delivered_at TIMESTAMP,
    completed_at TIMESTAMP,
    cancelled_at TIMESTAMP,

    food_rating INT CHECK (food_rating BETWEEN 1 AND 5),
    service_rating INT CHECK (service_rating BETWEEN 1 AND 5),
    delivery_rating INT CHECK (delivery_rating BETWEEN 1 AND 5),

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    deleted_at TIMESTAMP,

    CONSTRAINT fk_order_branch FOREIGN KEY (branch_id)
        REFERENCES branches(id) ON DELETE CASCADE,
    CONSTRAINT fk_order_customer FOREIGN KEY (customer_id) 
        REFERENCES users(id),
    CONSTRAINT fk_order_rider FOREIGN KEY (rider_id) 
        REFERENCES users(id),
    CONSTRAINT fk_order_waiter FOREIGN KEY (waiter_id) 
        REFERENCES users(id),
    CONSTRAINT fk_order_chef FOREIGN KEY (chef_id) 
        REFERENCES users(id),
    CONSTRAINT fk_order_table FOREIGN KEY (table_id) 
        REFERENCES restaurant_tables(id),
    CONSTRAINT fk_order_deal FOREIGN KEY (deal_id) 
        REFERENCES deals(id),
    CONSTRAINT fk_order_coupon FOREIGN KEY (coupon_id) 
        REFERENCES coupons(id)
);

CREATE INDEX idx_orders_branch ON orders(branch_id);
CREATE INDEX idx_orders_status ON orders(status);
CREATE INDEX idx_orders_customer ON orders(customer_id);
CREATE INDEX idx_orders_geo ON orders USING GIST (delivery_location);
CREATE INDEX idx_orders_created ON orders(created_at);

-- ============================================================================ 
-- ORDER STATUS TRANSITIONS (SAFETY)
-- ============================================================================ 
CREATE TABLE order_status_transitions (
    from_status VARCHAR(30),
    to_status VARCHAR(30),
    PRIMARY KEY (from_status, to_status)
);

