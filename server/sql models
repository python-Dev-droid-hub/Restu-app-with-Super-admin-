-- ============================================================================ 
-- ORDER ITEMS (UPDATED - Now includes size information)
-- ============================================================================ 
CREATE TABLE order_items (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    order_id UUID NOT NULL,
    product_id UUID NOT NULL,
    product_size_id UUID, -- Reference to product_sizes (if product has size)
    size_id UUID, -- Reference to sizes table (for historical record)

    product_name VARCHAR(255) NOT NULL,
    size_name VARCHAR(50), -- Size name for reference (copied from sizes table)
    quantity INT NOT NULL CHECK (quantity > 0),
    unit_price NUMERIC(10,2) NOT NULL,
    total_price NUMERIC(10,2) NOT NULL,
    
    -- Flag if this item has an active deal
    has_deal BOOLEAN DEFAULT FALSE,

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_item_order FOREIGN KEY (order_id)
        REFERENCES orders(id) ON DELETE CASCADE,
    CONSTRAINT fk_item_product FOREIGN KEY (product_id)
        REFERENCES products(id),
    CONSTRAINT fk_item_product_size FOREIGN KEY (product_size_id)
        REFERENCES product_sizes(id),
    CONSTRAINT fk_item_size FOREIGN KEY (size_id)
        REFERENCES sizes(id)
);

CREATE INDEX idx_order_items_order ON order_items(order_id);
CREATE INDEX idx_order_items_product ON order_items(product_id);

-- ============================================================================ 
-- ORDER ITEM CUSTOMIZATIONS (ANALYTICS-FRIENDLY)
-- ============================================================================ 
CREATE TABLE order_item_customizations (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    order_item_id UUID NOT NULL,
    option_name VARCHAR(100),
    option_value VARCHAR(100),
    extra_price NUMERIC(10,2) DEFAULT 0,

    CONSTRAINT fk_oic_item FOREIGN KEY (order_item_id)
        REFERENCES order_items(id) ON DELETE CASCADE
);

CREATE INDEX idx_customizations_order_item ON order_item_customizations(order_item_id);

-- ============================================================================ 
-- ORDER REJECTIONS
-- ============================================================================ 
CREATE TABLE order_rejections (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    order_id UUID NOT NULL,
    rejected_by UUID NOT NULL,
    rejection_type VARCHAR(20) CHECK (rejection_type IN ('KITCHEN','RIDER')),
    rejection_reason TEXT NOT NULL,
    is_resolved BOOLEAN DEFAULT FALSE,
    resolved_by UUID,
    resolved_at TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_reject_order FOREIGN KEY (order_id)
        REFERENCES orders(id) ON DELETE CASCADE,
    CONSTRAINT fk_reject_user FOREIGN KEY (rejected_by)
        REFERENCES users(id)
);

CREATE INDEX idx_rejections_order ON order_rejections(order_id);

-- ============================================================================ 
-- PAYMENTS (FINAL, SAFE)
-- ============================================================================ 
CREATE TABLE payments (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    payment_number VARCHAR(50) UNIQUE NOT NULL,

    order_id UUID NOT NULL,
    customer_id UUID NOT NULL,

    amount NUMERIC(12,2) NOT NULL,
    currency VARCHAR(10) DEFAULT 'PKR', -- Changed to PKR for Pakistan

    payment_method VARCHAR(50) NOT NULL,
    provider VARCHAR(50),

    status VARCHAR(20) CHECK (
        status IN ('PENDING','PROCESSING','SUCCESS','FAILED','REFUNDED')
    ),

    transaction_id VARCHAR(255),
    idempotency_key VARCHAR(255) UNIQUE,
    gateway_response JSONB,

    failure_reason TEXT,
    refund_amount NUMERIC(12,2),
    refund_reason TEXT,
    refunded_at TIMESTAMP,

    completed_at TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_payment_order FOREIGN KEY (order_id)
        REFERENCES orders(id),
    CONSTRAINT fk_payment_customer FOREIGN KEY (customer_id)
        REFERENCES users(id)
);

CREATE INDEX idx_payments_order ON payments(order_id);
CREATE INDEX idx_payments_customer ON payments(customer_id);
CREATE INDEX idx_payments_status ON payments(status);

-- ============================================================================ 
-- NOTIFICATIONS
-- ============================================================================ 
CREATE TABLE notifications (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    recipient_id UUID NOT NULL,
    title VARCHAR(255) NOT NULL,
    body TEXT NOT NULL,
    type VARCHAR(50),
    related_order_id UUID,
    is_read BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_notif_user FOREIGN KEY (recipient_id)
        REFERENCES users(id),
    CONSTRAINT fk_notif_order FOREIGN KEY (related_order_id)
        REFERENCES orders(id)
);

CREATE INDEX idx_notifications_user ON notifications(recipient_id, is_read);

-- ============================================================================ 
-- SYSTEM SETTINGS
-- ============================================================================ 
CREATE TABLE system_settings (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    key VARCHAR(100) UNIQUE NOT NULL,
    value JSONB NOT NULL,
    updated_by UUID,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_setting_user FOREIGN KEY (updated_by)
        REFERENCES users(id)
);

-- ============================================================================ 
-- BRANCH INVENTORY (NEW - Track inventory per branch)
-- ============================================================================ 
CREATE TABLE branch_inventory (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    branch_id UUID NOT NULL,
    product_id UUID NOT NULL,
    
    quantity_available INT DEFAULT 0,
    reorder_level INT DEFAULT 10, -- Alert when stock falls below this
    
    last_restocked_at TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    
    CONSTRAINT fk_inventory_branch FOREIGN KEY (branch_id)
        REFERENCES branches(id) ON DELETE CASCADE,
    CONSTRAINT fk_inventory_product FOREIGN KEY (product_id)
        REFERENCES products(id) ON DELETE CASCADE,
    CONSTRAINT unique_branch_product UNIQUE (branch_id, product_id)
);

CREATE INDEX idx_inventory_branch ON branch_inventory(branch_id);
CREATE INDEX idx_inventory_product ON branch_inventory(product_id);
CREATE INDEX idx_inventory_low_stock ON branch_inventory(quantity_available) 
    WHERE quantity_available <= reorder_level;

-- ============================================================================ 
-- HELPER FUNCTIONS
