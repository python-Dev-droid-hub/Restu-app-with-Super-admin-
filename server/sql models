-- View: Active Products with Sizes and Prices
CREATE OR REPLACE VIEW v_products_with_sizes AS
SELECT 
    p.id as product_id,
    p.name as product_name,
    p.description,
    p.category_id,
    c.name as category_name,
    p.price as base_price,
    p.has_sizes,
    s.id as size_id,
    s.size_name,
    ps.id as product_size_id,
    ps.price as size_price,
    ps.is_default,
    ps.is_available as size_available,
    p.image_url,
    p.is_available as product_available,
    p.preparation_time,
    p.is_vegetarian
FROM products p
LEFT JOIN categories c ON p.category_id = c.id
LEFT JOIN product_sizes ps ON p.id = ps.product_id AND ps.deleted_at IS NULL
LEFT JOIN sizes s ON ps.size_id = s.id AND s.deleted_at IS NULL
WHERE p.deleted_at IS NULL
    AND p.is_available = TRUE;

-- View: Branch Performance Summary
CREATE OR REPLACE VIEW v_branch_performance AS
SELECT 
    b.id as branch_id,
    b.branch_code,
    b.branch_name,
    b.city,
    COUNT(DISTINCT o.id) as total_orders,
    COUNT(DISTINCT CASE WHEN o.status = 'COMPLETED' THEN o.id END) as completed_orders,
    COUNT(DISTINCT CASE WHEN o.status = 'CANCELLED' THEN o.id END) as cancelled_orders,
    COALESCE(SUM(CASE WHEN o.status = 'COMPLETED' THEN o.total_amount END), 0) as total_revenue,
    COALESCE(AVG(CASE WHEN o.status = 'COMPLETED' THEN o.total_amount END), 0) as avg_order_value
FROM branches b
LEFT JOIN orders o ON b.id = o.branch_id AND o.deleted_at IS NULL
WHERE b.deleted_at IS NULL
GROUP BY b.id, b.branch_code, b.branch_name, b.city;

-- View: Products with Active Deals
CREATE OR REPLACE VIEW v_products_with_deals AS
SELECT 
    p.id as product_id,
    p.name as product_name,
    d.id as deal_id,
    d.title as deal_title,
    d.discount_type,
    d.discount_value,
    d.branch_id,
    b.branch_name,
    d.start_date,
    d.expiry_date,
    d.exclude_coupons
FROM products p
INNER JOIN deal_products dp ON p.id = dp.product_id
INNER JOIN deals d ON dp.deal_id = d.id
LEFT JOIN branches b ON d.branch_id = b.id
WHERE p.deleted_at IS NULL
    AND d.deleted_at IS NULL
    AND d.is_active = TRUE
    AND CURRENT_TIMESTAMP BETWEEN d.start_date AND d.expiry_date;

