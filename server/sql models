-- Function to check if a product has an active deal
CREATE OR REPLACE FUNCTION has_active_deal(p_product_id UUID, p_branch_id UUID)
RETURNS BOOLEAN AS $$
DECLARE
    deal_count INT;
BEGIN
    SELECT COUNT(*) INTO deal_count
    FROM deal_products dp
    INNER JOIN deals d ON dp.deal_id = d.id
    WHERE dp.product_id = p_product_id
        AND d.is_active = TRUE
        AND d.deleted_at IS NULL
        AND CURRENT_TIMESTAMP BETWEEN d.start_date AND d.expiry_date
        AND (d.branch_id = p_branch_id OR d.branch_id IS NULL);
    
    RETURN deal_count > 0;
END;
$$ LANGUAGE plpgsql;

-- Function to validate coupon usage on order items
CREATE OR REPLACE FUNCTION validate_coupon_on_order(p_order_id UUID, p_coupon_id UUID)
RETURNS BOOLEAN AS $$
DECLARE
    coupon_exclude_deals BOOLEAN;
    order_branch_id UUID;
    deal_product_count INT;
BEGIN
    -- Get coupon exclude_deal_products flag
    SELECT exclude_deal_products INTO coupon_exclude_deals
    FROM coupons
    WHERE id = p_coupon_id;
    
    -- If coupon doesn't exclude deal products, allow it
    IF coupon_exclude_deals = FALSE THEN
        RETURN TRUE;
    END IF;
    
    -- Get order's branch
    SELECT branch_id INTO order_branch_id
    FROM orders
    WHERE id = p_order_id;
    
    -- Check if any order items have active deals
    SELECT COUNT(*) INTO deal_product_count
    FROM order_items oi
    WHERE oi.order_id = p_order_id
        AND has_active_deal(oi.product_id, order_branch_id);
    
    -- If any items have deals, coupon cannot be applied
    RETURN deal_product_count = 0;
END;
$$ LANGUAGE plpgsql;

