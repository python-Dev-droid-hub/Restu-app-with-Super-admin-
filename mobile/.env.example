# Restaurant App Mobile Environment Variables
# Copy this file to .env and fill in your actual values

# ==========================================
# API Configuration
# ==========================================
# Development API URL (your computer's IP address)
# Find your IP: Windows (ipconfig) | Mac/Linux (ifconfig)
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api

# Production API URL
EXPO_PUBLIC_API_URL_PRODUCTION=https://your-production-api.com/api

# ==========================================
# App Configuration
# ==========================================
# App Environment: development | staging | production
EXPO_PUBLIC_APP_ENV=development

# Enable/Disable debug logging
EXPO_PUBLIC_DEBUG_MODE=true

# ==========================================
# Payment Configuration (Stripe)
# ==========================================
# Stripe Publishable Key (test mode)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Publishable Key (production)
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_your_live_stripe_key_here

# ==========================================
# Feature Flags
# ==========================================
# Enable/Disable specific features
EXPO_PUBLIC_ENABLE_PAYMENTS=true
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_LOCATION=true

# ==========================================
# Third Party Services
# ==========================================
# Google Maps API Key (for location features)
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# OneSignal App ID (for push notifications)
# EXPO_PUBLIC_ONESIGNAL_APP_ID=your_onesignal_app_id

# Sentry DSN (for error tracking)
# EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn

# ==========================================
# Admin/Development
# ==========================================
# Default admin credentials (development only)
# EXPO_PUBLIC_DEV_ADMIN_EMAIL=admin@example.com
# EXPO_PUBLIC_DEV_ADMIN_PASSWORD=admin123

# Test branch ID (for development)
# EXPO_PUBLIC_DEV_BRANCH_ID=your_test_branch_id
