# Copy to .env on your VPS: cp .env.production.example .env
# Then: docker compose up -d --build
# Or bare metal: bash scripts/deploy-vps-bare.sh

# Public URLs (replace with your server IP or domain)
PUBLIC_HOST=31.97.189.252
SERVER_URL=http://31.97.189.252:3101
CORS_ORIGIN=http://31.97.189.252:5175
FRONTEND_URL=http://31.97.189.252:5175

# Web build (Docker sets proxy to http://server:3101 automatically)
VITE_API_URL=/api

# HTTP VPS — required for login cookies over http://IP:5175
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Auth (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=replace_with_64_char_hex
JWT_REFRESH_SECRET=replace_with_64_char_hex

# HTTP VPS (no TLS yet)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# HTTPS later: COOKIE_SECURE=true COOKIE_SAMESITE=none
