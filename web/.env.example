# Dev: Vite proxies /api → backend (recommended)
VITE_PROXY_TARGET=http://127.0.0.1:3101
VITE_API_URL=/api

# Production build on VPS (docker): keep VITE_API_URL=/api — web proxies to server:3101
# Direct API URL only if you use nginx same-host or a separate API subdomain:
# VITE_API_URL=http://31.97.189.252:3101/api

VITE_APP_NAME=Restaurant App
VITE_APP_ENV=development
